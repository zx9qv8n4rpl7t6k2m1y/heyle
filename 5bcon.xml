    <div id="bar">
        <div id="fill"><img id="spider" alt="" src="html5game/spider.png"/></div>
    </div>

    <div id="decor">

        <img class="torch" id="t1" src="html5game/torch.gif" alt=""/>
        <img class="torch" id="t2" src="html5game/torch.gif" alt=""/>
